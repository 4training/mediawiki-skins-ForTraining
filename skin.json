{
  "name": "ForTraining",
  "version": "0.1.0",
  "author": ["holybiber"],
  "url": "https://github.com/4training/mediawiki-skins-ForTraining",
  "descriptionmsg": "fortraining-skin-desc",
  "namemsg": "skinname-fortraining",
  "license-name": "GPL2",
  "type": "skin",
  "requires": {
    "MediaWiki": ">= 1.39.0"
  },
  "ValidSkinNames": {
    "fortraining": {
      "class": "SkinForTraining",
      "args": [
        {
          "name": "fortraining",
          "responsive": true,
          "messages": [
            "fortraining-no-categories",
            "sitetitle",
            "search",
            "otherlanguages",
            "tagline",
            "navigation-heading"
          ],
          "styles": [
            "mediawiki.ui.icon",
            "mediawiki.ui.button",
            "skins.fortraining.styles",
            "skins.fortraining.usermenu.styles",
            "skins.fortraining.language-menu.styles",
            "skins.fortraining.burger-menu-accordion.styles"
          ],
          "scripts": [
            "skins.tailwindburger.js",
            "skins.fortraining.usermenu",
            "skins.fortraining.dropdown-languages-menu",
            "skins.fortraining.set-editor-to-expanded",
            "skins.fortraining.burgermenu-accordion"
          ]
        }
      ]
    }
  },
  "MessagesDirs": {
    "ForTraining": ["i18n"]
  },
  "AutoloadClasses": {
    "SkinForTraining": "includes/SkinForTraining.php"
  },
  "ResourceModules": {
    "skins.fortraining.icons": {
      "targets": ["desktop", "mobile"],
      "packageFiles": [
        "resources/assets/icons/user-menu-gear.svg",
        "resources/assets/icons/language-menu.svg"
      ]
    },
    "skins.fortraining.usermenu.styles": {
      "targets": ["desktop", "mobile"],
      "styles": ["resources/assets/css/user-menu-styles.css"]
    },
    "skins.fortraining.language-menu.styles": {
      "targets": ["desktop", "mobile"],
      "styles": ["resources/assets/css/dropdown-languages.css"]
    },
    "skins.fortraining.burger-menu-accordion.styles": {
      "targets": ["desktop", "mobile"],
      "styles": ["resources/assets/css/burger-menu-accordion.css"]
    },
    "skins.fortraining.styles": {
      "class": "ResourceLoaderSkinModule",
      "features": {
        "normalize": true,
        "elements": true,
        "content-tables": true,
        "content-links": false,
        "content-media": false,
        "content-links-external": false,
        "interface-message-box": true,
        "interface-category": false,
        "toc": true
      },
      "targets": ["desktop", "mobile"],
      "styles": {
        "resources/skin.less": {
          "media": "screen"
        },
        "resources/dist/tailwind.css": {
          "media": "screen"
        }
      }
    },
    "skins.tailwindburger.js": {
      "targets": ["desktop", "mobile"],
      "packageFiles": ["resources/tailwindburger.js"]
    },
    "skins.fortraining.usermenu": {
      "targets": ["desktop", "mobile"],
      "packageFiles": ["resources/user-menu-toggle.js"]
    },
    "skins.fortraining.dropdown-languages-menu": {
      "targets": ["desktop", "mobile"],
      "packageFiles": ["resources/dropdown-languages-toggle.js"]
    },
    "skins.fortraining.set-editor-to-expanded": {
      "targets": ["desktop", "mobile"],
      "packageFiles": ["resources/set-editor-to-expanded.js"]
    },
    "skins.fortraining.burgermenu-accordion": {
      "targets": ["desktop", "mobile"],
      "packageFiles": ["resources/burger-menu-accordion.js"]
    }
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteSkinPath": "ForTraining"
  },
  "ResourceModuleSkinStyles": {
    "fortraining": {
      "+ext.echo.styles.badge": "resources/extensions/echo.styles.badge.less"
    }
  },
  "manifest_version": 2
}