<div id="ft-wrapper" class="min-h-screen bg-white">
  {{>Header}}
  <main id="ft-content" class="flex-grow container mx-auto px-4 py-8">
    <div id="siteNotice"
         class="hidden mb-4 bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4">{{{html-site-notice}}}</div>
    {{{html-user-message}}}
    <div class="text-4xl font-bold"> {{{html-title-heading}}}</div>
    <div class="flex mt-4">
      {{#array-indicators}}
        <div id="{{id}}" class="{{class}}">{{{html}}}</div>
      {{/array-indicators}}
    </div>
    <div class="flex justify-end">
      {{>LanguagesMenu}}
    </div>
    <div class="bg-white rounded-lg shadow-xl p-6">
      <div id="contentSub" class="text-sm text-gray-600 mb-4">
        {{{html-subtitle}}}
        {{{html-undelete-link}}}
      </div>
      <div class="prose max-w-none">
        {{{html-body-content}}}
      </div>
      {{#data-portlets}}
        {{>CategoryPortlet}}
      {{/data-portlets}}
    </div>
    {{{html-after-content}}}
  </main>

  <footer id="footer" class="mw-footer p-6 bg-gray-100"
          role="contentinfo" {{{html-user-language-attributes}}}>
    <div class="container mx-auto">
      <nav id="mw-navigation" class="mb-6">
        <div class="flex space-between">
          <div id="mw-head" class="flex items-center space-x-4">
            <div>
              {{#data-footer}}
                {{#data-icons}}{{>FooterList}}{{/data-icons}}
                {{^user-logged-in}}
                  {{#data-portlets.data-user-interface-preferences}}
                    <div class="footer-language-selector mt-2 list-none text-lg">
                      {{{html-items}}}
                    </div>
                  {{/data-portlets.data-user-interface-preferences}}
                {{/user-logged-in}}
                {{#data-info}}{{>FooterList}}{{/data-info}}
              {{/data-footer}}
            </div>
          </div>
        </div>
      </nav>
      <div class="footer-final mt-4 pt-4 border-t border-gray-300 text-lg">
        <a href="/Special:MyLanguage/About">{{msg-footer-about}}</a>
        <span class="mx-2">|</span>
        <a href="/Special:MyLanguage/Donate">{{msg-footer-donate}}</a>
      </div>
    </div>
  </footer>
</div>
